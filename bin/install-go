#!/usr/bin/env bash
set -euo pipefail

VERSION=${1:-}

# Detect platform if not specified
if [ -z "${2:-}" ]; then
    OS=$(uname -s | tr '[:upper:]' '[:lower:]')
    ARCH=$(uname -m)
    case "$OS" in linux) OS_NAME="linux" ;; darwin) OS_NAME="darwin" ;; *) echo "Unsupported OS: $OS"; exit 1 ;; esac
    case "$ARCH" in x86_64) ARCH_NAME="amd64" ;; aarch64|arm64) ARCH_NAME="arm64" ;; *) echo "Unsupported architecture: $ARCH"; exit 1 ;; esac
    PLATFORM="${OS_NAME}-${ARCH_NAME}"
else
    PLATFORM="$2"
fi

if [ -z "${GOROOT:-}" ] || [ -z "${GOPATH:-}" ]; then
    echo "Please, set GOROOT and GOPATH in your environment."
    exit 1
fi

if [ -z "$VERSION" ]; then
    VERSION=$(curl -fsSL "https://go.dev/VERSION?m=text" | sed -n '1s/^go//p')
fi

TMP_DIR=$(mktemp -d)
trap 'rm -rf -- "$TMP_DIR"' EXIT

if command -v go >/dev/null 2>&1; then
    go version
fi

GO_TAR="$TMP_DIR/go.tar.gz"
PACKAGE_NAME="go$VERSION.$PLATFORM.tar.gz"
#URL="https://storage.googleapis.com/golang/$PACKAGE_NAME"
URL="https://go.dev/dl/$PACKAGE_NAME"
echo "Downloading $URL ... to $TMP_DIR"
if ! curl -# -fL -o "$GO_TAR" "$URL"; then
    echo "Download failed!"
    exit 1
fi

if ! tar -tzf "$GO_TAR" >/dev/null 2>&1; then
    echo "Downloaded file is not a valid .tar.gz archive."
    echo "Check that Go version '$VERSION' exists for platform '$PLATFORM'."
    exit 1
fi

if [ -d "$GOROOT" ]; then
    echo "The Go install directory ($GOROOT) already exists, replacing it."
    rm -rf "$GOROOT"
fi

mkdir -p "$GOPATH" "$GOROOT"
tar -C "$GOROOT" --strip-components=1 -xzf "$GO_TAR"

echo -e "\nGo $VERSION was installed into $GOROOT."
