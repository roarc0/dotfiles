#!/usr/bin/env bash
#
# Track a config folder: copies it into dotfiles, removes the original,
# and creates a symlink back. Useful for managing configs across machines.
#
# Usage:
#   dotfiles-track-config ~/.config/myapp
#   dotfiles-track-config ~/.ssh
#

set -e

if [ $# -ne 1 ]; then
  echo "Usage: track-config <path>"
  echo "  Example: track-config ~/.config/nvim"
  exit 1
fi

SOURCE="$(eval echo "$1")"
BASENAME="$(basename "$SOURCE")"
ENV_HOME="${ENV_HOME:-$(cd "$(dirname "$0")/.." && pwd)}"
DEST="$ENV_HOME/dotfiles/config/$BASENAME"

# Validate source exists
if [ ! -e "$SOURCE" ]; then
  echo "Error: $SOURCE does not exist"
  exit 1
fi

# Check if already tracked
if [ -L "$SOURCE" ] && [ "$(readlink "$SOURCE")" = "$DEST" ]; then
  echo "Already tracked: $SOURCE -> $DEST"
  exit 0
fi

# Warn if destination exists
if [ -e "$DEST" ]; then
  echo "Warning: $DEST already exists"
  read -p "Overwrite? (y/n) " -n 1 -r
  echo
  if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    exit 1
  fi
  rm -rf "$DEST"
fi

# Create parent directory if needed
mkdir -p "$(dirname "$DEST")"

# Move source to repo
echo "Moving $SOURCE -> $DEST"
mv "$SOURCE" "$DEST"

# Create symlink
echo "Linking $SOURCE <- $DEST"
ln -sf "$DEST" "$SOURCE"

echo "✓ Config tracked: $SOURCE"
echo "  Repo: $DEST"
echo ""
echo "Next: cd $ENV_HOME && git add dotfiles/config/$BASENAME && git commit -m \"track config: $BASENAME\""
