#!/usr/bin/env bash
#
# Track a config folder: copies it into dotfiles, removes the original,
# and creates a symlink back. Useful for managing configs across machines.
#
# Usage:
#   dotfiles-track-config ~/.config/myapp
#   dotfiles-track-config ~/.ssh
#

set -e

supports_color=false
supports_emoji=false
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ] && command -v tput >/dev/null 2>&1; then
  if [ "$(tput colors 2>/dev/null || echo 0)" -ge 8 ]; then
    supports_color=true
  fi
fi
if [ -t 1 ]; then
  case "${LC_ALL:-${LC_CTYPE:-${LANG:-}}}" in
    *UTF-8*|*utf8*) supports_emoji=true ;;
  esac
fi

if [ "$supports_color" = true ]; then
  C_RESET='\033[0m'
  C_GREEN='\033[32;1m'
  C_YELLOW='\033[33;1m'
  C_RED='\033[31;1m'
  C_BLUE='\033[34;1m'
else
  C_RESET=''
  C_GREEN=''
  C_YELLOW=''
  C_RED=''
  C_BLUE=''
fi

if [ "$supports_emoji" = true ]; then
  P_INFO='ℹ️ '
  P_OK='✅ '
  P_WARN='⚠️ '
  P_ERR='❌ '
else
  P_INFO='[INFO] '
  P_OK='[OK] '
  P_WARN='[WARN] '
  P_ERR='[ERROR] '
fi

info() { printf "%b%s%s%b\n" "$C_BLUE" "$P_INFO" "$*" "$C_RESET"; }
ok() { printf "%b%s%s%b\n" "$C_GREEN" "$P_OK" "$*" "$C_RESET"; }
warn() { printf "%b%s%s%b\n" "$C_YELLOW" "$P_WARN" "$*" "$C_RESET"; }
err() { printf "%b%s%s%b\n" "$C_RED" "$P_ERR" "$*" "$C_RESET"; }

if [ $# -ne 1 ]; then
  err "Usage: dotfiles-track-config <path>"
  info "Example: dotfiles-track-config ~/.config/nvim"
  exit 1
fi

SOURCE="$(eval echo "$1")"
BASENAME="$(basename "$SOURCE")"
ENV_HOME="${ENV_HOME:-$(cd "$(dirname "$0")/.." && pwd)}"
DEST="$ENV_HOME/dotfiles/config/$BASENAME"

# Validate source exists
if [ ! -e "$SOURCE" ]; then
  err "$SOURCE does not exist"
  exit 1
fi

# Check if already tracked
if [ -L "$SOURCE" ] && [ "$(readlink "$SOURCE")" = "$DEST" ]; then
  ok "Already tracked: $SOURCE -> $DEST"
  exit 0
fi

# Warn if destination exists
if [ -e "$DEST" ]; then
  warn "$DEST already exists"
  read -p "Overwrite? (y/n) " -n 1 -r
  echo
  if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    exit 1
  fi
  rm -rf "$DEST"
fi

# Create parent directory if needed
mkdir -p "$(dirname "$DEST")"

# Move source to repo
info "Moving $SOURCE -> $DEST"
mv "$SOURCE" "$DEST"

# Create symlink
info "Linking $SOURCE <- $DEST"
ln -sf "$DEST" "$SOURCE"

ok "Config tracked: $SOURCE"
info "Repo: $DEST"
info "Next: cd $ENV_HOME && git add dotfiles/config/$BASENAME && git commit -m \"track config: $BASENAME\""
