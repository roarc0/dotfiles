#!/usr/bin/env bash
#
# Detect untracked config changes: compares tracked configs with live ones using meld
# Useful for catching edits that were made to live configs instead of tracked ones
#
# Usage:
#   dotfiles-check-config-sync           # Check all configs
#   dotfiles-check-config-sync nvim      # Check specific config (dotfiles/config/nvim vs ~/.config/nvim)
#

set -e

supports_color=false
supports_emoji=false
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ] && command -v tput >/dev/null 2>&1; then
  if [ "$(tput colors 2>/dev/null || echo 0)" -ge 8 ]; then
    supports_color=true
  fi
fi
if [ -t 1 ]; then
  case "${LC_ALL:-${LC_CTYPE:-${LANG:-}}}" in
    *UTF-8*|*utf8*) supports_emoji=true ;;
  esac
fi

if [ "$supports_color" = true ]; then
  C_RESET='\033[0m'
  C_GREEN='\033[32;1m'
  C_YELLOW='\033[33;1m'
  C_RED='\033[31;1m'
  C_BLUE='\033[34;1m'
else
  C_RESET=''
  C_GREEN=''
  C_YELLOW=''
  C_RED=''
  C_BLUE=''
fi

if [ "$supports_emoji" = true ]; then
  P_OK='✅ '
  P_WARN='⚠️ '
  P_ERR='❌ '
  P_INFO='ℹ️ '
else
  P_OK='[OK] '
  P_WARN='[WARN] '
  P_ERR='[ERROR] '
  P_INFO='[INFO] '
fi

ok() { printf "%b%s%s%b\n" "$C_GREEN" "$P_OK" "$*" "$C_RESET"; }
warn() { printf "%b%s%s%b\n" "$C_YELLOW" "$P_WARN" "$*" "$C_RESET"; }
err() { printf "%b%s%s%b\n" "$C_RED" "$P_ERR" "$*" "$C_RESET"; }
info() { printf "%b%s%s%b\n" "$C_BLUE" "$P_INFO" "$*" "$C_RESET"; }

ENV_HOME="${ENV_HOME:-$(cd "$(dirname "$0")/.." && pwd)}"
DOTFILES="$ENV_HOME/dotfiles"

# Determine CONFIG_DIR based on OS
if [[ "$OSTYPE" == "darwin"* ]]; then
  CONFIG_DIR="$HOME/Library/Application Support"
else
  CONFIG_DIR="$HOME/.config"
fi

# Check if meld is installed
if ! type meld >/dev/null 2>&1; then
  err "meld is not installed"
  info "Install with: sudo apt install meld (Linux) or brew install meld (macOS)"
  exit 1
fi

check_config() {
  local name="$1"
  local tracked="$DOTFILES/config/$name"
  local live="$CONFIG_DIR/$name"

  # Skip if tracked version doesn't exist
  [ -e "$tracked" ] || return 0

  # If live version doesn't exist, nothing to check
  if [ ! -e "$live" ]; then
    info "Missing: $live (not yet installed)"
    return 0
  fi

  # If it's a proper symlink to tracked, all good
  if [ -L "$live" ] && [ "$(readlink "$live")" = "$tracked" ]; then
    ok "Synced: $name"
    return 0
  fi

  # Not a symlink or points elsewhere - show diff
  warn "Out of sync: $name"
  info "Tracked: $tracked"
  info "Live:    $live"

  # Compare and open meld if different
  if ! diff -r "$tracked" "$live" >/dev/null 2>&1; then
    info "Opening meld..."
    meld "$tracked" "$live" 2>/dev/null &
  else
    info "Contents identical, but not symlinked properly"
    # Re-establish symlink
    read -p "  Re-link? (y/n) " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
      rm -rf "$live"
      ln -sf "$tracked" "$live"
      ok "Re-linked"
    fi
  fi
}

# If argument given, check specific config
if [ $# -gt 0 ]; then
  for name in "$@"; do
    check_config "$name"
  done
  exit 0
fi

# Check all tracked configs
info "Checking all tracked configs..."

any_out_of_sync=false
for tracked in "$DOTFILES"/config/*; do
  name="$(basename "$tracked")"
  if ! check_config "$name"; then
    any_out_of_sync=true
  fi
done

if [ "$any_out_of_sync" = false ]; then
  ok "All configs in sync"
else
  warn "Some configs out of sync (meld windows opened)"
fi
