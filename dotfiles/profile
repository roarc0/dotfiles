if [ -n "$GOPATH" ]; then
    export PATH="${GOPATH}/bin:$PATH"
fi

if [ -d "$HOME/.local/bin" ]; then
    export PATH="$HOME/.local/bin:$PATH"
fi

export GIT_TERMINAL_PROMPT=1
export EDITOR=nvim
export VISUAL=$EDITOR
export MERGETOOL=meld
export AWS_PAGER=""
unset SSH_ASKPASS

# Work-related environment
export GOPRIVATE="github.com/c-wire/*"

if [ -f "$HOME/workspace/.profile" ]; then
    . "$HOME/workspace/.profile"
fi

# LLM-related environment
export PATH="$PATH:$HOME/.lmstudio/bin"
export LLAMA_CPP_PATH="$HOME/.local/llama.cpp"
export PATH="$PATH:$LLAMA_CPP_PATH"
